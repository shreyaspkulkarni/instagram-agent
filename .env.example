# Anthropic (caption generation)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini vision + embeddings)
GOOGLE_API_KEY=...

# Instagram / Meta OAuth (optional — auth is disabled in current version)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/auth/instagram/callback

# Apify (one-time RAG scraping)
APIFY_API_TOKEN=

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=instagram_agent
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=instagram_agent

# PostgreSQL connection string
# Local dev:
DATABASE_URL=postgresql://instagram_agent:password@localhost:5433/instagram_agent
# Production (docker-compose.prod.yml overrides this automatically):
# DATABASE_URL=postgresql://instagram_agent:YOUR_PASSWORD@postgres:5432/instagram_agent

# Redis
REDIS_URL=redis://localhost:6379/0
# Production: REDIS_URL=redis://redis:6379/0

# App
SECRET_KEY=change_this_to_a_long_random_string
FRONTEND_URL=http://localhost:3000
